{
  "manifest_version": 3,
  "name": "Script Runner",
  "version": "1.0.0",
  "description": "在 Side Panel 中编写和运行脚本",
  "permissions": [
    "sidePanel",
    "scripting",
    "activeTab",
    "ai"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "打开 Script Runner"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
